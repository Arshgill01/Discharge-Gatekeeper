# Runtime environment. Supported values: local | dev | prod
PO_ENV=local

# MCP HTTP listener
HOST=0.0.0.0
PORT=5056

# MCP metadata shown to clients
MCP_SERVER_NAME=Clinical Intelligence MCP
MCP_SERVER_VERSION=1.0.0

# Comma-separated host allowlist for inbound Host headers.
ALLOWED_HOSTS=localhost,127.0.0.1

# LLM provider configuration
# heuristic | google
CLINICAL_INTELLIGENCE_LLM_PROVIDER=heuristic
CLINICAL_INTELLIGENCE_LLM_TIMEOUT_MS=12000
CLINICAL_INTELLIGENCE_GOOGLE_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=
