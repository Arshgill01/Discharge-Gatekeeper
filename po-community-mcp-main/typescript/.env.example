# Runtime environment. Supported values: local | dev | prod
PO_ENV=local

# MCP HTTP listener
HOST=0.0.0.0
PORT=5055

# MCP metadata shown to clients
MCP_SERVER_NAME=Discharge Gatekeeper MCP
MCP_SERVER_VERSION=1.0.0

# Comma-separated host allowlist for inbound Host headers.
# Include your tunnel hostname when testing from Prompt Opinion.
# Entries may be hostnames (example.ngrok-free.app) or full URLs (https://example.ngrok-free.app).
ALLOWED_HOSTS=localhost,127.0.0.1
