# Runtime environment: local | dev | prod
PO_ENV=local

# MCP HTTP listener
HOST=0.0.0.0
PORT=5000

# MCP metadata shown to clients
MCP_SERVER_NAME=Discharge Gatekeeper MCP
MCP_SERVER_VERSION=1.0.0

# Comma-separated host allowlist for inbound Host headers.
# Include your tunnel hostname when testing from Prompt Opinion.
ALLOWED_HOSTS=localhost,127.0.0.1
