{
  "name": "discharge-gatekeeper-mcp-server-ts",
  "version": "1.0.0",
  "description": "TypeScript MCP server for Discharge Gatekeeper discharge-readiness workflows",
  "main": "index.ts",
  "scripts": {
    "start": "npx tsx index.ts",
    "typecheck": "npx tsc --noEmit",
    "smoke:readiness": "npx tsx smoke/assess-discharge-readiness-smoke.ts",
    "smoke:readiness:regression": "npx tsx smoke/assess-discharge-readiness-regression.ts",
    "test": "npm run typecheck && npm run smoke:readiness && npm run smoke:readiness:regression"
  },
  "author": "Discharge Gatekeeper Team",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@smile-cdr/fhirts": "^2.3.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "jose": "^6.0.11",
    "zod": "^4.2.1"
  }
}
